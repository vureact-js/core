{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@src/*": ["src/*"],
      "@compiler/*": ["src/compiler/*"],
      "@core/*": ["src/core/*"],
      "@parse/*": ["src/core/parse/*"],
      "@transform/*": ["src/core/transform/*"],
      "@codegen/*": ["src/core/codegen/*"],
      "@utils/*": ["src/utils/*"],
      "@shared/*": ["src/shared/*"],
      "@consts/*": ["src/consts/*"],
      "@plugins/*": ["src/plugins/*"]
    }
  },
  "include": ["src", "**/__tests__", "**/__tests__/**/*"]
}
