    "cac": "^6.7.14",
    "chokidar": "^5.0.0",
    "kleur": "^4.1.5",
    "less": "^4.5.1",
    "minimatch": "^10.1.1",
    "ora": "^9.1.0",
    "postcss": "^8.5.6",
