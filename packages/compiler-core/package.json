{
  "name": "@vureact/compiler-core",
  "version": "1.0.0",
  "description": "Compile Vue 3 code into React 18+ (JSX/TSX), supporting automated batch processing, precise logic migration, and core adapter packages to simplify component migration from Vue to React.",
  "author": "Ryan John",
  "license": "MIT",
  "type": "module",
  "main": "./lib/compiler-core.cjs",
  "module": "./lib/compiler-core.mjs",
  "types": "./lib/compiler-core.d.ts",
  "exports": {
    ".": {
      "types": "./lib/compiler-core.d.ts",
      "import": "./lib/compiler-core.mjs",
      "require": "./lib/compiler-core.cjs"
    }
  },
  "files": [
    "bin",
    "lib"
  ],
  "keywords": [
    "vue",
    "react",
    "vureact",
    "vue-to-react",
    "vue-to-jsx",
    "react-vue-like",
    "compiler",
    "transformer",
    "typescript",
    "jsx",
    "tsx",
    "esm"
  ],
  "homepage": "https://vureact.vercel.app/en",
  "repository": {
    "type": "git",
    "url": "https://github.com/vureact-js/core.git",
    "directory": "packages/compiler-core"
  },
  "bugs": {
    "url": "https://github.com/vureact-js/core/issues"
  },
  "bin": {
    "vureact": "./bin/vureact.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsx watch"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.28.5",
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "@vue/compiler-core": "^3.5.22",
    "@vue/compiler-sfc": "^3.5.22",
    "cac": "^6.7.14",
    "chokidar": "^5.0.0",
    "kleur": "^4.1.5",
    "minimatch": "^10.1.1",
    "ora": "^9.1.0",
    "postcss": "^8.5.6",
    "xxhashjs": "^0.2.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}