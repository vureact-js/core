{
  "name": "@vureact/compiler-core",
  "version": "1.0.0",
  "description": "A modern automatic compilation tool that quickly converts Vue3 code to React (Jsx/Tsx). It meets the daily business and component engineering needs of small and medium-sized projects, enabling lossless syntax conversion and precise logic migration. Leverage Vue's mental model advantages to write React code—ready to use right after conversion.",
  "author": "Owen Dells",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.cjs", 
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./parse": {
      "types": "./lib/parse/index.d.ts",
      "import": "./lib/parse/index.mjs",
      "require": "./lib/parse/index.cjs"
    },
    "./transform": {
      "types": "./lib/transform/index.d.ts",
      "import": "./lib/transform/index.mjs",
      "require": "./lib/transform/index.cjs"
    },
    "./codegen": {
      "types": "./lib/codegen/index.d.ts",
      "import": "./lib/codegen/index.mjs",
      "require": "./lib/codegen/index.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "vue",
    "react",
    "vureact",
    "vue-to-jsx",
    "vue-to-react",
    "react-vue-like",
    "vue-sfc-transformer",
    "compiler",
    "transformer"
  ],
  "homepage": "https://vureact.vercel.app/docs/en/compiler-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/smirk9581/vureact.git",
    "directory": "packages/compiler-core"
  },
  "bugs": {
    "url": "https://github.com/smirk9581/vureact/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsx watch",
    "dev:parse": "tsx watch src/core/parse/__tests__/index.ts",
    "dev:transform": "tsx watch src/core/transform/__tests__/index.ts",
    "dev:codegen": "tsx watch src/core/codegen/__tests__/index.ts"
  },
  "dependencies": {
    "@babel/core": "^7.28.5",
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "@vue/compiler-core": "^3.5.22",
    "@vue/compiler-sfc": "^3.5.22",
    "kleur": "^4.1.5"
  }
}