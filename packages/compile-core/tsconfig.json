{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@src/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@utils/*": ["utils/*"],
      "@shared/*": ["shared/*"],
      "@consts/*": ["consts/*"]
    }
  },
  "include": ["src"]
}
