{
  "name": "vureact",
  "version": "1.0.0",
  "description": "A modern automatic compilation tool that quickly converts Vue3 code to React (Jsx/Tsx). It meets the daily business and component engineering needs of small and medium-sized projects, enabling lossless syntax conversion and precise logic migration. Leverage Vue's mental model advantages to write React code—ready to use right after conversion.",
  "author": "Owen Dells",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./parse": {
      "import": "./lib/core/parse/index.js",
      "types": "./lib/core/parse/index.d.ts"
    },
    "./transform": {
      "import": "./lib/core/transform/index.js",
      "types": "./lib/core/transform/index.d.ts"
    },
    "./codegen": {
      "import": "./lib/core/codegen/index.js",
      "types": "./lib/core/codegen/index.d.ts"
    }
  },
  "files": [
    "lib",
    "LICENSE",
    "README.md",
    "README.zh.md"
  ],
  "keywords": [
    "vue",
    "react",
    "vureact",
    "vue-to-jsx",
    "vue-to-react",
    "react-vue-like",
    "babel",
    "compiler",
    "transformer",
    "template-transformer"
  ],
  "homepage": "https://vureact.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/smirk9581/vureact/packages/compile-core"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsx watch",
    "dev:parse": "tsx watch src/core/parse/__tests__/index.ts",
    "dev:transform": "tsx watch src/core/transform/__tests__/index.ts",
    "dev:codegen": "tsx watch src/core/codegen/__tests__/index.ts"
  },
  "dependencies": {
    "@babel/core": "^7.28.5",
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "@vue/compiler-core": "^3.5.22",
    "@vue/compiler-sfc": "^3.5.22",
    "kleur": "^4.1.5"
  }
}