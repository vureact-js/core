{
  "name": "@vureact/runtime-core",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/cjs/runtime-core.cjs",
  "module": "./dist/esm/runtime-core.mjs",
  "types": "./dist/types/runtime-core.d.ts",
  "author": "Ryan John",
  "license": "MIT",
  "description": "React adapter for Vue 3's built-in components, reactive APIs, partial template v-directive value processing utilities, as well as basic and commonly used Vue Router adaptations.",
  "keywords": [
    "react",
    "vureact-runtime",
    "react-hooks",
    "react-components",
    "react-vue-like",
    "react-vue-adapter"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/runtime-core.d.ts",
      "import": "./dist/esm/runtime-core.mjs",
      "require": "./dist/cjs/runtime-core.cjs"
    },
    "./adapter-components": {
      "types": "./dist/types/adapter-components.d.ts",
      "import": "./dist/esm/adapter-components.mjs",
      "require": "./dist/cjs/adapter-components.cjs"
    },
    "./adapter-hooks": {
      "types": "./dist/types/adapter-hooks.d.ts",
      "import": "./dist/esm/adapter-hooks.mjs",
      "require": "./dist/cjs/adapter-hooks.cjs"
    },
    "./adapter-utils": {
      "types": "./dist/types/adapter-utils.d.ts",
      "import": "./dist/esm/adapter-utils.mjs",
      "require": "./dist/cjs/adapter-utils.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://vureact.vercel.app/en/runtime-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/smirk9581/vureact.git",
    "directory": "packages/runtime-core"
  },
  "bugs": {
    "url": "https://github.com/smirk9581/vureact/issues"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && rollup -c --bundleConfigAsCjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "react-transition-group": "^4.4.5",
    "freeze-mutate": "^1.3.0",
    "immer": "^10.2.0",
    "klona": "^2.0.6",
    "react-fast-compare": "^3.2.2",
    "use-immer": "^0.11.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  }
}