{
  "name": "@vureact/runtime-core",
  "version": "1.1.1",
  "type": "module",
  "main": "./dist/cjs/runtime-core.js",
  "module": "./dist/esm/runtime-core.esm.js",
  "types": "./dist/types/runtime-core.d.ts",
  "author": "Ruihong Zhong (Ryan John)",
  "license": "MIT",
  "description": "🌀 Bring Vue 3's built-in components, reactive APIs, and template directives to React applications.",
  "keywords": [
    "react",
    "vureact",
    "vureact-runtime",
    "react-hooks",
    "react-components",
    "react-vue-like",
    "react-vue-adapter",
    "vue-to-react",
    "vue3-in-react",
    "react-adapter",
    "vue-adapter",
    "keepalive-react",
    "transition-react",
    "teleport-react",
    "reactive-react",
    "valtio",
    "react-ecosystem",
    "vue-ecosystem",
    "component-cache",
    "react-performance",
    "vue-like-syntax",
    "template-directives",
    "useReactive",
    "useWatch",
    "useComputed",
    "react-migration",
    "vue-migration",
    "framework-interop",
    "cross-framework",
    "hybrid-framework",
    "developer-experience",
    "dx-tools"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/runtime-core.d.ts",
      "import": "./dist/esm/runtime-core.esm.js",
      "require": "./dist/cjs/runtime-core.js"
    },
    "./adapter-components": {
      "types": "./dist/types/adapter-components.d.ts",
      "import": "./dist/esm/adapter-components.esm.js",
      "require": "./dist/cjs/adapter-components.js"
    },
    "./adapter-hooks": {
      "types": "./dist/types/adapter-hooks.d.ts",
      "import": "./dist/esm/adapter-hooks.esm.js",
      "require": "./dist/cjs/adapter-hooks.js"
    },
    "./adapter-utils": {
      "types": "./dist/types/adapter-utils.d.ts",
      "import": "./dist/esm/adapter-utils.esm.js",
      "require": "./dist/cjs/adapter-utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://runtime.vureact.top",
  "repository": {
    "type": "git",
    "url": "https://github.com/vureact-js/core.git",
    "directory": "packages/runtime-core"
  },
  "bugs": {
    "url": "https://github.com/vureact-js/core/issues"
  },
  "scripts": {
    "build": "rimraf dist && rollup -c --bundleConfigAsCjs",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "freeze-mutate": "^1.3.0",
    "klona": "^2.0.6",
    "react-fast-compare": "^3.2.2",
    "react-transition-group": "^4.4.5",
    "valtio": "^2.3.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  }
}