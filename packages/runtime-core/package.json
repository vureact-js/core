{
  "name": "@vureact/runtime-core",
  "version": "1.0.0",
  "type": "module",
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/index.d.ts",
  "author": "Owen Dells",
  "license": "MIT",
  "description": "",
  "keywords": [
    "react",
    "vureact-runtime",
    "react-hooks",
    "react-components",
    "vue-to-react-adapt"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs"
    },
    "./adapter-components": {
      "types": "./lib/adapter-components.d.ts",
      "import": "./lib/esm/adapter-components.mjs",
      "require": "./lib/cjs/adapter-components.cjs"
    },
    "./adapter-hooks": {
      "types": "./lib/adapter-hooks.d.ts",
      "import": "./lib/esm/adapter-hooks.mjs",
      "require": "./lib/cjs/adapter-hooks.cjs"
    },
    "./adapter-utils": {
      "types": "./lib/adapter-utils.d.ts",
      "import": "./lib/esm/adapter-utils.mjs",
      "require": "./lib/cjs/adapter-utils.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "homepage": "https://vureact.vercel.app/docs/en/runtime-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/smirk9581/vureact.git",
    "directory": "packages/runtime-core"
  },
  "bugs": {
    "url": "https://github.com/smirk9581/vureact/issues"
  },
  "scripts": {
    "clean": "rimraf lib",
    "build": "pnpm clean && rollup -c --bundleConfigAsCjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "react-transition-group": "^4.4.5",
    "freeze-mutate": "^1.3.0",
    "immer": "^10.2.0",
    "klona": "^2.0.6",
    "react-fast-compare": "^3.2.2",
    "use-immer": "^0.11.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0",
    "react-router-dom": ">=7.9.0"
  }
}